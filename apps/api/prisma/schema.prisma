generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  relationMode = "prisma"
}

enum AdviceCategory {
  GROWTH_HEALTH
  DEVELOPMENT
  NUTRITION_FEEDING
  SLEEP
  PLAY_ACTIVITIES
  PARENT_WELLBEING
}

enum ContentSource {
  CLINICAL
  DEVELOPMENT
  EXPERT
  PARENT_COMMUNITY
  GENERAL
}

enum MilestoneDomain {
  MOTOR
  GROSS_MOTOR
  FINE_MOTOR
  COGNITIVE
  LANGUAGE
  LANGUAGE_COMMUNICATION
  SOCIAL_EMOTIONAL
  SELF_HELP
}

enum MilestoneStatus {
  EXPECTED
  EMERGING
  ADVANCED
  RED_FLAG
}

model ExpertAdviceCard {
  id           String         @id @default(uuid())
  stageKey     String
  category     AdviceCategory
  priority     Int            @default(50)
  title        String
  summary      String
  content      String
  source       ContentSource  @default(DEVELOPMENT)
  tags         String[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  SavedAdvice  SavedAdvice[]
  AdviceRating AdviceRating[]

  @@index([stageKey])
  @@index([category])
  @@index([priority])
}

model RoutineTemplate {
  id              String        @id @default(uuid())
  stageKey        String        @unique
  title           String
  description     String?
  category        String?
  wakeWindowMins  Int?
  napCount        Int?
  totalNapHours   Float?
  nightSleepHours Float?
  feedFrequency   String?
  sampleSchedule  Json?
  bedtimeRitual   Json?
  flexible        Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  UserRoutine     UserRoutine[]

  @@index([stageKey])
}

model MilestoneExpectation {
  id              String          @id @default(uuid())
  stageKey        String
  domain          MilestoneDomain
  title           String
  description     String
  status          MilestoneStatus @default(EXPECTED)
  ageRangeMinDays Int?
  ageRangeMaxDays Int?
  redFlagText     String?
  activityPrompt  String?
  xpReward        Int             @default(10)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  BabyMilestone   BabyMilestone[]

  @@index([stageKey, domain])
  @@index([domain])
}

model VaccinationSchedule {
  id              String   @id @default(uuid())
  vaccineName     String
  diseasePrevents String
  dueAgeMonths    Float
  dueAgeWeeks     Int?
  doseNumber      Int      @default(1)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([dueAgeMonths])
}

model ScreeningReminder {
  id             String   @id @default(uuid())
  title          String
  description    String?
  dueAgeMonths   Float
  targetAgeDays  Int?
  screeningTool  String?
  targetAudience String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([dueAgeMonths])
}

enum GrowthType {
  WEIGHT
  HEIGHT
  HEAD_CIRCUMFERENCE
}

model UserRoutine {
  id             String    @id @default(uuid())
  userId         String
  babyMonId      String?
  templateId     String
  routineDate    DateTime?
  stageKey       String?
  completedSteps Json      @default("[]")
  customizations Json?
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user     User            @relation(fields: [userId], references: [id])
  template RoutineTemplate @relation(fields: [templateId], references: [id])

  @@unique([babyMonId, routineDate])
  @@index([userId])
}

model BabyMilestone {
  id            String    @id @default(uuid())
  babyMonId     String
  expectationId String
  achievedAt    DateTime?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  babyMon   BabyMon              @relation(fields: [babyMonId], references: [id], onDelete: Cascade)
  milestone MilestoneExpectation @relation(fields: [expectationId], references: [id])

  @@unique([babyMonId, expectationId])
  @@index([babyMonId])
}

model SavedAdvice {
  id           String   @id @default(uuid())
  userId       String
  babyMonId    String?
  adviceCardId String
  createdAt    DateTime @default(now())

  user   User             @relation(fields: [userId], references: [id])
  advice ExpertAdviceCard @relation(fields: [adviceCardId], references: [id])
  babyMon BabyMon?        @relation("BabyMonSavedAdvice", fields: [babyMonId], references: [id], onDelete: SetNull)

  @@unique([userId, adviceCardId])
  @@index([userId])
}

model AdviceRating {
  id           String   @id @default(uuid())
  userId       String
  adviceCardId String
  rating       Int
  helpful      Boolean?
  comment      String?
  createdAt    DateTime @default(now())

  user   User             @relation(fields: [userId], references: [id])
  advice ExpertAdviceCard @relation(fields: [adviceCardId], references: [id])

  @@unique([userId, adviceCardId])
  @@index([adviceCardId])
}

model User {
  id                  String    @id @default(uuid())
  email               String    @unique
  passwordHash        String?
  name                String?
  phone               String?
  role                String    @default("USER") // USER, ADMIN
  isActive            Boolean   @default(true)
  verificationToken   String?
  verificationExpires DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  verifiedAt          DateTime?
  deletedAt           DateTime?

  tosAcceptedAt       DateTime?
  tosVersion          String?
  privacyAcceptedAt   DateTime?
  privacyVersion      String?
  consentDataAt       DateTime?

  notificationsEnabled Boolean  @default(true)
  pushMilestones       Boolean  @default(true)  // push: milestone alerts
  pushBadges           Boolean  @default(true)  // push: badge unlocks
  pushGrowth           Boolean  @default(true)  // push: growth analysis
  pushProposals        Boolean  @default(true)  // push: co-parent proposals
  quietHoursStart      String?  // HH:mm format, e.g. "22:00"
  quietHoursEnd        String?  // HH:mm format, e.g. "07:00"

  babyMons            BabyMon[]
  linkedAccountsAsA   LinkedAccount[]       @relation("UserA")
  linkedAccountsAsB   LinkedAccount[]       @relation("UserB")
  refreshTokens       RefreshToken[]
  subscriptions       Subscription[]
  auditLogs           AuditLog[]
  milestones          Milestone[]
  feedLogs            FeedLog[]
  sleepLogs           SleepLog[]
  healthRecords       HealthRecord[]
  proposals           EntryChangeProposal[] @relation("Proposer")
  linkedBabyMons      LinkedBabyMon[]
  media               Media[]
  growthRecords       GrowthRecord[]
  allergies           Allergy[]
  medicalTeams        MedicalTeam[]
  allergyEvents       AllergyEvent[]
  devices             Device[]
  passwordResetTokens PasswordResetToken[]
  UserRoutine         UserRoutine[]
  SavedAdvice         SavedAdvice[]
  AdviceRating        AdviceRating[]
  journalProposed     JournalProposal[] @relation("JournalProposer")
  promoRedemptions    PromoRedemption[]
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Device {
  id           String   @id @default(uuid())
  userId       String
  deviceToken  String   @unique
  platform     String // ios, android, web
  createdAt    DateTime @default(now())
  lastActiveAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model LinkedAccount {
  id        String    @id @default(uuid())
  userAId   String
  userBId   String
  status    String    @default("PENDING")
  // Partner role (PARENT / GUARDIAN / GRANDPARENT) — stored as a free-form
  // string with DTO-level validation so adding roles doesn't require a migration.
  role      String?   @default("PARENT")
  // The BabyMon this invitation grants access to. Resolved on accept so the
  // invitee gets a LinkedBabyMon row for this specific baby.
  babyMonId String?
  createdAt DateTime  @default(now())
  linkedAt  DateTime?
  expiresAt DateTime?

  userA   User     @relation("UserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB   User     @relation("UserB", fields: [userBId], references: [id], onDelete: Cascade)
  babyMon BabyMon? @relation("LinkedAccountBabyMon", fields: [babyMonId], references: [id], onDelete: SetNull)

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
  @@index([status])
  @@index([babyMonId])
}

model LinkedBabyMon {
  id        String   @id @default(uuid())
  userId    String
  babymonId String
  access    String   @default("EDIT")
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  babyMon BabyMon @relation(fields: [babymonId], references: [id], onDelete: Cascade)

  @@unique([userId, babymonId])
  @@index([userId])
  @@index([babymonId])
}

model BabyMon {
  id               String    @id @default(uuid())
  ownerUserId      String
  name             String
  middleName       String?
  lastName         String?
  stageStartType   String
  conceptionDate   DateTime?
  lmpDate          DateTime?
  birthDate        DateTime?
  gestationalAgeAtBirth Int? // weeks at birth (<37 = premature)
  dueDate          DateTime?
  ideaDate         DateTime?
  gender           String
  traits           String[]
  traitsUpdatedAt   DateTime? // tracks when traits were last changed (for badge criteria)
  specialMove      String?
  biologicalMother String?
  biologicalFather String?
  bloodGroup       String?
  eyeColor         String?
  siblingGroupId   String? // shared ID for twins/multiples
  currentXp        Int       @default(0)
  currentStage     Int       @default(1)
  isGraduated       Boolean   @default(false) // archived after 24 months
  graduatedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  owner            User                  @relation(fields: [ownerUserId], references: [id])
  milestones       Milestone[]
  feedLogs         FeedLog[]
  sleepLogs        SleepLog[]
  healthRecords    HealthRecord[]
  badges           Badge[]
  auditLogs        AuditLog[]
  proposals        EntryChangeProposal[] @relation("BabyMonProposal")
  journalProposals JournalProposal[]
  stageContent     StageContent[]
  linkedUsers      LinkedBabyMon[]
  linkedAccounts   LinkedAccount[]       @relation("LinkedAccountBabyMon")
  media            Media[]
  growthRecords    GrowthRecord[]
  allergies        Allergy[]
  medicalTeams     MedicalTeam[]
  allergyEvents    AllergyEvent[]
  BabyMilestone    BabyMilestone[]
  savedAdvice      SavedAdvice[]         @relation("BabyMonSavedAdvice")
  dailyActivities  DailyActivity[]

  @@index([ownerUserId])
  @@index([deletedAt])
  @@index([siblingGroupId])
}

model Milestone {
  id             String    @id @default(uuid())
  babymonId      String
  authorUserId   String
  title          String
  notes          String?
  happenedAt     DateTime
  localMediaRefs String[]
  isCustom       Boolean   @default(false)
  syncStatus     String    @default("SYNCED")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?
  xpAwarded      Int       @default(10)

  babymon BabyMon @relation(fields: [babymonId], references: [id], onDelete: Cascade)
  author  User    @relation(fields: [authorUserId], references: [id])

  @@index([babymonId])
  @@index([authorUserId])
  @@index([happenedAt])
  @@index([deletedAt])
  @@index([babymonId, happenedAt])
}

model FeedLog {
  id             String    @id @default(uuid())
  babymonId      String
  authorUserId   String
  type           String
  amount         String?
  unit           String?
  notes          String?
  happenedAt     DateTime
  localMediaRefs String[]
  syncStatus     String    @default("SYNCED")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?
  xpAwarded      Int       @default(5)

  babymon BabyMon @relation(fields: [babymonId], references: [id], onDelete: Cascade)
  author  User    @relation(fields: [authorUserId], references: [id])

  @@index([babymonId])
  @@index([authorUserId])
  @@index([happenedAt])
  @@index([deletedAt])
  @@index([babymonId, happenedAt])
}

model HealthRecord {
  id             String    @id @default(uuid())
  babymonId      String
  authorUserId   String
  category       String
  title          String
  value          String?
  unit           String?
  notes          String?
  happenedAt     DateTime
  localMediaRefs String[]
  syncStatus     String    @default("SYNCED")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?
  xpAwarded      Int       @default(5)

  babymon BabyMon @relation(fields: [babymonId], references: [id], onDelete: Cascade)
  author  User    @relation(fields: [authorUserId], references: [id])

  @@index([babymonId])
  @@index([authorUserId])
  @@index([happenedAt])
  @@index([deletedAt])
  @@index([babymonId, happenedAt])
}

model SleepLog {
  id             String    @id @default(uuid())
  babymonId      String
  authorUserId   String
  type           String
  startTime      DateTime
  endTime        DateTime
  quality        Int?
  notes          String?
  happenedAt     DateTime  @default(now())
  localMediaRefs String[]
  syncStatus     String    @default("SYNCED")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?
  xpAwarded      Int       @default(5)

  babymon BabyMon @relation(fields: [babymonId], references: [id], onDelete: Cascade)
  author  User    @relation(fields: [authorUserId], references: [id])

  @@index([babymonId])
  @@index([authorUserId])
  @@index([startTime])
  @@index([deletedAt])
}

model Badge {
  id          String   @id @default(uuid())
  babymonId   String
  badgeType   String
  name        String
  icon        String?
  description String?
  xpValue     Int      @default(10)
  unlockedAt  DateTime @default(now())

  babymon BabyMon @relation(fields: [babymonId], references: [id], onDelete: Cascade)

  @@unique([babymonId, badgeType])
}

model StageContent {
  id                String   @id @default(uuid())
  babymonId         String?
  stageKey          String
  weekNumber        Int?
  monthNumber       Int?
  isPostBirth       Boolean  @default(false)
  summaryText       String
  nurturingText     String
  encouragementText String
  xpThreshold       Int      @default(0)

  babymon BabyMon? @relation(fields: [babymonId], references: [id], onDelete: Cascade)

  @@unique([babymonId, stageKey])
  @@index([stageKey])
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum SubscriptionTier {
  FREE
  PREMIUM
}

model Subscription {
  id                   String           @id @default(uuid())
  userId               String
  tier                 SubscriptionTier @default(FREE)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  stripePriceId        String?
  trialStartDate       DateTime  @default(now())
  trialEndDate         DateTime
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  isActive             Boolean   @default(true)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum PromoCodeType {
  TRIAL_EXTEND
  FULL_PREMIUM
}

model PromoCode {
  id                 String         @id @default(uuid())
  code               String         @unique
  type               PromoCodeType
  valueDays          Int            // how many days of access this grants
  maxRedemptions     Int?           // null = unlimited
  currentRedemptions Int            @default(0)
  isActive           Boolean        @default(true)
  expiresAt          DateTime?
  createdBy          String?        // admin note
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  redemptions PromoRedemption[]
}

model PromoRedemption {
  id          String   @id @default(uuid())
  promoCodeId String
  userId      String
  redeemedAt  DateTime @default(now())

  promoCode PromoCode @relation(fields: [promoCodeId], references: [id])
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([promoCodeId, userId])
  @@index([userId])
}

model AuditLog {
  id          String   @id @default(uuid())
  babymonId   String?
  actorUserId String
  eventType   String
  payloadJson Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  babymon BabyMon? @relation(fields: [babymonId], references: [id])
  actor   User     @relation(fields: [actorUserId], references: [id])

  @@index([babymonId])
  @@index([actorUserId])
  @@index([createdAt])
  @@index([eventType])
}

model EntryChangeProposal {
  id                  String    @id @default(uuid())
  babymonId           String
  proposerUserId      String
  entryType           String
  entryId             String
  proposalType        String
  status              String    @default("PENDING")
  proposedPayloadJson String
  originalPayloadJson String?
  responseReason      String?
  createdAt           DateTime  @default(now())
  expiresAt           DateTime
  autoAcceptedAt      DateTime?
  respondedAt         DateTime?

  babymon  BabyMon @relation("BabyMonProposal", fields: [babymonId], references: [id], onDelete: Cascade)
  proposer User    @relation("Proposer", fields: [proposerUserId], references: [id])

  @@index([babymonId])
  @@index([proposerUserId])
  @@index([status])
}

model StripeEvent {
  id        String   @id @default(uuid())
  eventId   String   @unique
  type      String
  data      String
  processed Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Media {
  id           String   @id @default(uuid())
  babyMonId    String
  userId       String
  fileName     String
  fileType     String
  fileSize     Int
  s3Key        String
  url          String
  thumbnailUrl String?
  createdAt    DateTime @default(now())

  babymon BabyMon @relation(fields: [babyMonId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@index([babyMonId])
  @@index([userId])
  @@index([createdAt])
}

enum ProposalStatus {
  PENDING
  APPROVED
  REJECTED
}

model JournalProposal {
  id             String         @id @default(uuid())
  babymonId      String
  journalEntryId String // Milestone/FeedLog/HealthRecord ID
  entryType      String // MILESTONE, FEED_LOG, HEALTH_RECORD
  proposedById   String // userId of co-parent who proposed
  changes        Json // { field: "notes", oldValue: "...", newValue: "..." }
  status         ProposalStatus @default(PENDING)
  createdAt      DateTime       @default(now())
  resolvedAt     DateTime?
  resolvedById   String?

  babymon BabyMon @relation(fields: [babymonId], references: [id], onDelete: Cascade)
  proposer User    @relation("JournalProposer", fields: [proposedById], references: [id], onDelete: Cascade)

  @@index([babymonId])
  @@index([proposedById])
  @@index([status])
}

model GrowthRecord {
  id         String   @id @default(uuid())
  babyMonId  String
  userId     String
  type       GrowthType // HEIGHT, WEIGHT, HEAD_CIRCUMFERENCE
  value      Float
  unit       String // cm, kg, in, lb
  measuredAt DateTime
  notes      String?
  deletedAt  DateTime?
  createdAt  DateTime @default(now())

  babymon BabyMon @relation(fields: [babyMonId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@index([babyMonId])
  @@index([measuredAt])
  @@index([deletedAt])
}

model Allergy {
  id        String    @id @default(uuid())
  babyMonId String
  userId    String
  name      String
  triggers  String? // comma-separated triggers
  severity  String? // Mild / Moderate / Severe
  treatment String? // EpiPen / Antihistamine / Avoidance / etc.
  notes     String?
  status    String    @default("ACTIVE") // ACTIVE, CURED
  curedAt   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  babymon BabyMon        @relation(fields: [babyMonId], references: [id], onDelete: Cascade)
  user    User           @relation(fields: [userId], references: [id])
  events  AllergyEvent[]

  @@unique([babyMonId, name])
  @@index([babyMonId])
}

model AllergyEvent {
  id         String   @id @default(uuid())
  allergyId  String
  babyMonId  String
  userId     String
  happenedAt DateTime @default(now())
  notes      String?
  deletedAt  DateTime?
  createdAt  DateTime @default(now())

  allergy Allergy @relation(fields: [allergyId], references: [id], onDelete: Cascade)
  babymon BabyMon @relation(fields: [babyMonId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@index([allergyId])
  @@index([babyMonId])
  @@index([happenedAt])
}

model MedicalTeam {
  id        String    @id @default(uuid())
  babyMonId String
  userId    String
  name      String
  specialty String?
  facility  String?
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  babymon BabyMon @relation(fields: [babyMonId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([babyMonId, name])
  @@index([babyMonId])
  @@index([facility])
  @@index([specialty])
}

/// Tracks one row per baby per day with activity — enables streak detection
model DailyActivity {
  id         String   @id @default(uuid())
  babymonId  String
  date       DateTime // date-only (time is always 00:00:00)
  hasMilestone Boolean @default(false)
  hasFeedLog   Boolean @default(false)
  hasSleepLog  Boolean @default(false)
  hasHealthRecord Boolean @default(false)
  hasGrowthRecord Boolean @default(false)
  createdAt  DateTime @default(now())

  babymon BabyMon @relation(fields: [babymonId], references: [id], onDelete: Cascade)

  @@unique([babymonId, date])
  @@index([babymonId])
}
