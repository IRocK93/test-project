# ===========================================
# DATABASE
# ===========================================
DATABASE_URL="postgresql://babymon:babymon_dev_password@localhost:5432/babymon?schema=public"
DATABASE_POOL_SIZE=5
DATABASE_URL_READ_REPLICA=""

# ===========================================
# AUTHENTICATION
# ===========================================
# Generate with: openssl rand -hex 64
JWT_SECRET="your-super-secret-jwt-key-min-32-chars-long"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ===========================================
# STRIPE (Payment Processing)
# ===========================================
# Get from Stripe Dashboard -> Developers -> API Keys
STRIPE_SECRET_KEY="sk_test_your_test_key"
STRIPE_PUBLISHABLE_KEY="pk_test_your_publishable_key"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"

# Price IDs from Stripe Dashboard -> Products
STRIPE_PRICE_CORE_MONTHLY="price_core_monthly_id"
STRIPE_PRICE_CORE_YEARLY="price_core_yearly_id"
STRIPE_PRICE_AI_MONTHLY="price_ai_monthly_id"
STRIPE_PRICE_AI_YEARLY="price_ai_yearly_id"

# ===========================================
# AWS (S3 for media storage)
# ===========================================
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your_access_key"
AWS_SECRET_ACCESS_KEY="your_secret_key"
S3_BUCKET_NAME="babymon-media"

# ===========================================
# APPLICATION
# ===========================================
PORT=3000
NODE_ENV="development" # development | staging | production
API_URL="http://localhost:3000"
FRONTEND_URL="http://localhost:5173"

# ===========================================
# SECURITY
# ===========================================
# Rate limiting (optional - defaults will be used)
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# CORS origins (comma-separated)
CORS_ORIGINS="http://localhost:5173,http://localhost:3000"

# ===========================================
# TRIAL CONFIGURATION
# ===========================================
TRIAL_DAYS=14

# ===========================================
# LOGGING & MONITORING
# ===========================================
LOG_LEVEL="debug" # debug | log | warn | error
AUDIT_RETENTION_DAYS=2555 # 7 years for compliance

# ===========================================
# SENTRY (Error Tracking) - Optional
# ===========================================
# SENTRY_DSN="https://xxx@sentry.io/xxx"
