# ===========================================
# DATABASE
# ===========================================
DATABASE_URL="postgresql://babymon:babymon_dev_password@localhost:5432/babymon?schema=public"
DATABASE_POOL_SIZE=5
DATABASE_URL_READ_REPLICA=""

# ===========================================
# AUTHENTICATION
# ===========================================
# Generate with: openssl rand -hex 64
JWT_SECRET="your-super-secret-jwt-key-min-32-chars-long"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ===========================================
# STRIPE (Payment Processing)
# ===========================================
# Get from Stripe Dashboard -> Developers -> API Keys
STRIPE_SECRET_KEY="sk_test_your_test_key"
STRIPE_PUBLISHABLE_KEY="pk_test_your_publishable_key"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"

# Price IDs from Stripe Dashboard -> Products
STRIPE_PRICE_FREE_MONTHLY="price_free_monthly_id"
STRIPE_PRICE_FREE_YEARLY="price_free_yearly_id"
STRIPE_PRICE_PREMIUM_MONTHLY="price_premium_monthly_id"
STRIPE_PRICE_PREMIUM_YEARLY="price_premium_yearly_id"

# ===========================================
# AWS (S3 for media storage)
# ===========================================
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your_access_key"
AWS_SECRET_ACCESS_KEY="your_secret_key"
S3_BUCKET_NAME="babymon-media"

# ===========================================
# APPLICATION
# ===========================================
PORT=3000
NODE_ENV="development" # development | staging | production
API_URL="http://localhost:3000"
FRONTEND_URL="http://localhost:5173"

# ===========================================
# SECURITY
# ===========================================
# Rate limiting (optional - defaults will be used)
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# CORS origins (comma-separated)
CORS_ORIGINS="http://localhost:5173,http://localhost:3000"

# ===========================================
# TRIAL CONFIGURATION
# ===========================================
TRIAL_DAYS=14

# ===========================================
# DEV / TESTING
# ===========================================
# Set to "true" to bypass TierGuard subscription checks in development
SKIP_TIER_GUARD=true
# Email of the user to automatically grant PREMIUM tier on seed
PREMIUM_USER_EMAIL=premium-user@babymon.app

# ===========================================
# AI COMPANION — On-device LLM model
# ===========================================
# URL to the GGUF model file for the AI Companion's on-device LLM.
# The mobile app downloads the model at first use.
#
# Two modes:
#   ABSOLUTE URL → mobile downloads directly (use for CDN in production):
#     COMPANION_MODEL_URL="https://cdn.example.com/models/model.gguf"
#
#   RELATIVE PATH → mobile downloads through the backend proxy (dev/testing):
#     COMPANION_MODEL_URL="/api/models/companion-llm/download"
#     The backend fetches from HuggingFace and streams to the client.
#     Use this when devices/emulators can't reach external URLs directly.
COMPANION_MODEL_URL="/api/models/companion-llm/download"

# SHA-256 hex digest of the model file (optional).
# Leave empty to skip integrity verification.
COMPANION_MODEL_SHA256=""
LOG_LEVEL="debug" # debug | log | warn | error
AUDIT_RETENTION_DAYS=2555 # 7 years for compliance

# ===========================================
# SENTRY (Error Tracking) - Optional
# ===========================================
# SENTRY_DSN="https://xxx@sentry.io/xxx"
